# ---- Copy this file to .env and fill in your keys ----

# Groq (required) — https://console.groq.com/keys
# NOTE: if GROQ_API_KEY is already set in your system environment, that one wins
# (python-dotenv does not override existing env vars). You can leave this as-is then.
GROQ_API_KEY=your_groq_api_key_here

# Tavily (required for the web-search agent, lesson 05) — https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# LangSmith (optional, tracing/observability) — https://smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
# Uncomment to turn tracing ON (requires a valid LANGSMITH_API_KEY above):
#LANGSMITH_TRACING=true
LANGSMITH_PROJECT=langchain-groq-lab
# Uncomment if you are on the LangSmith EU instance:
#LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
